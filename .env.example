# TDX 運輸資料流通服務 API 金鑰
# 申請：https://tdx.transportdata.tw/
VITE_TDX_CLIENT_ID=your_client_id_here
VITE_TDX_CLIENT_SECRET=your_client_secret_here

# Google Places API 金鑰（伺服器端用，不需 VITE_ 前綴）
# 申請：https://console.cloud.google.com
# 需啟用：Places API (New), Maps JavaScript API
GOOGLE_PLACES_API_KEY=your_google_api_key_here

# 電子發票 API（伺服器端用）
# 申請：https://www.einvoice.nat.gov.tw
EINVOICE_APP_ID=your_einvoice_app_id_here
EINVOICE_API_KEY=your_einvoice_api_key_here
